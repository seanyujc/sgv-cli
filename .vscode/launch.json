{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Weapp Build",
      "skipFiles": ["${workspaceFolder}/node_modules"],
      "preLaunchTask": "npm: build",
      "program": "${workspaceFolder}/lib/sgv-mini.js",
      "args": ["build", "-s", "user"],
      "env": { "NODE_PROJECT_ROOT": "../sgv-tpl-weapp" },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Build Service Method",
      "skipFiles": ["${workspaceFolder}/node_modules"],
      "preLaunchTask": "npm: build",
      "program": "${workspaceFolder}/lib/sgv-build.js",
      "args": ["-s", "common", "-f", "logout"],
      "env": { "NODE_PROJECT_ROOT": "../sgv-tpl-vite" },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Build Page",
      "skipFiles": ["${workspaceFolder}/node_modules"],
      "preLaunchTask": "npm: build",
      "program": "${workspaceFolder}/lib/sgv-build.js",
      "args": ["-p", "subject/sae/default"],
      "env": { "NODE_PROJECT_ROOT": "../../front/TrialLab/TrialLab_H5" },
      "console": "integratedTerminal"
    }
  ]
}
